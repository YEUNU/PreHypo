# --- Neo4j (required) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- OpenAI (required for the LLM judge during benchmarking) ---
OPENAI_API_KEY=
# Combined judge + hallucination call; pick any chat-completions model.
EVAL_MODEL=gpt-5.5-2026-04-23
# Route the judge through the OpenAI Batch API (50% cheaper) instead of one
# sync call per query. Opt-in; OpenAI EVAL_MODEL only. The run waits for the
# batch to finish (no client timeout; up to 24h). Falls back to sync on failure.
RAG_JUDGE_BATCH=false
RAG_JUDGE_BATCH_POLL_SECONDS=15

# --- vLLM endpoints (defaults match run_servers.sh) ---
VLLM_URL=http://localhost:28000/v1
# Optional second generation endpoint for round-robin load balancing
# VLLM_URL_2=http://localhost:28010/v1
VLLM_EMBED_URL=http://localhost:18082/v1
VLLM_OCR_URL=http://localhost:28001/v1
VLLM_RERANK_URL=http://localhost:18083/v1
VLLM_API_KEY=EMPTY

# vLLM --served-model-name values
VLLM_SERVED_MODEL_NAME=generation-model
VLLM_SERVED_EMBED_MODEL_NAME=embedding-model
VLLM_SERVED_OCR_MODEL_NAME=ocr-model

# --- GPU placement for run_servers.sh (defaults target a 2-GPU box) ---
# Single GPU? Set all to 0 (and lower --gpu-memory-utilization if they don't fit).
GEN_GPU=1
GEN2_GPU=0
OCR_GPU=1
EMBED_GPU=0
RERANK_GPU=1

# --- Retrieval / chunking thresholds (paper Table 5) ---
NEO4J_VECTOR_DIMENSIONS=1024
MAX_EMBEDDING_LENGTH=16384
NEO4J_FULLTEXT_ANALYZER=english
RAG_ENABLE_QUERY_REWRITE=True
RAG_QUERY_REWRITE_COUNT=2
RAG_QUERY_REWRITE_WEIGHT=0.85
RAG_META_BOOST_WEIGHT=0.35
RAG_BOILERPLATE_PENALTY_WEIGHT=0.25

# --- Indexing ablations (paper Table 2). All default true. ---
RAG_ABLATION_TABLE=True
RAG_ABLATION_CHUNKING=True
RAG_ABLATION_SUMMARY=True
RAG_ABLATION_Q_PLUS=True
RAG_ABLATION_Q_MINUS=True

# --- Reproducibility ---
# RAG_LLM_SEED=42
# RAG_BENCHMARK_SEEDS=0,1,2,3,4
